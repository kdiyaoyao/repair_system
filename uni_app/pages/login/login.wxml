<view class="page-wrapper">
  <view class="top-bg"></view>
  
  <view class="login-container">
    <view class="login-box">
      <view class="header">
        <text class="title">智慧社区报修</text>
        <view class="title-line"></view>
        <text class="subtitle">老旧小区物业响应系统</text>
      </view>

      <view class="input-section">
        <view class="input-item">
          <text class="input-label">账号</text>
          <view class="input-wrapper">
            <input placeholder="请输入用户名" placeholder-class="ph-style" bindinput="onUsernameInput" class="my-input"/>
          </view>
        </view>
        
        <view class="input-item">
          <text class="input-label">密码</text>
          <view class="input-wrapper">
            <input placeholder="请输入密码" password placeholder-class="ph-style" bindinput="onPasswordInput" class="my-input"/>
          </view>
        </view>
      </view>

      <button class="login-btn" hover-class="btn-hover" bindtap="handleLogin">立即登录</button>
      
      <view class="footer">
        <text>毕业设计演示系统 v1.0</text>
      </view>
    </view>
  </view>
</view>