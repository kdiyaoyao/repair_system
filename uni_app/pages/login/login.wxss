page {
  background-color: #f6f7fb;
  height: 100vh;
}

.page-wrapper {
  position: relative;
  height: 100%;
  overflow: hidden;
}

/* 顶部蓝色渐变装饰 */
.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 400rpx;
  background: linear-gradient(180deg, #007aff 0%, #f6f7fb 100%);
  z-index: 1;
}

.login-container {
  position: relative;
  z-index: 10;
  padding: 120rpx 50rpx 0;
}

.login-box {
  background: #ffffff;
  border-radius: 40rpx;
  padding: 80rpx 50rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.08);
}

/* 标题设计 */
.header {
  margin-bottom: 80rpx;
  text-align: left;
}

.title {
  font-size: 52rpx;
  font-weight: 800;
  color: #1d1d1f;
  display: block;
}

.title-line {
  width: 60rpx;
  height: 8rpx;
  background: #007aff;
  margin: 16rpx 0;
  border-radius: 4rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #8e8e93;
  letter-spacing: 2rpx;
}

/* 输入区域 */
.input-item {
  margin-bottom: 40rpx;
}

.input-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #3a3a3c;
  margin-bottom: 16rpx;
  display: block;
  padding-left: 4rpx;
}

.input-wrapper {
  background: #f2f2f7;
  border-radius: 16rpx;
  padding: 0 30rpx;
  height: 100rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid transparent;
  transition: all 0.3s ease;
}

.my-input {
  width: 100%;
  height: 100%;
  font-size: 30rpx;
  color: #1d1d1f;
}

.ph-style {
  color: #aeaeb2;
}

/* 登录按钮 */
.login-btn {
  margin-top: 80rpx;
  background: #007aff;
  color: #ffffff;
  height: 110rpx;
  line-height: 110rpx;
  border-radius: 55rpx;
  font-size: 34rpx;
  font-weight: 600;
  box-shadow: 0 10rpx 30rpx rgba(0, 122, 255, 0.3);
  border: none;
}

.btn-hover {
  transform: scale(0.98);
  background: #0063cc;
}

.footer {
  margin-top: 60rpx;
  text-align: center;
}

.footer text {
  font-size: 22rpx;
  color: #c7c7cc;
  letter-spacing: 1rpx;
}