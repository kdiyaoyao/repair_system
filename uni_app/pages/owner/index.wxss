/* 1. 基础容器与顶部装饰 */
.page-container {
  min-height: 100vh;
  background-color: #f8f9fa;
  position: relative;
}

.top-cover {
  height: 280rpx;
  background: linear-gradient(180deg, #2f54eb 0%, #597ef7 100%);
  border-radius: 0 0 60rpx 60rpx;
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  z-index: 0;
}

/* 2. 头部信息与消息红点 */
.main-content {
  position: relative;
  z-index: 1;
  padding: 0 30rpx;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 40rpx 0;
  color: #ffffff;
}

.user-info .welcome {
  font-size: 28rpx;
  opacity: 0.9;
  display: block;
}

.user-info .title {
  font-size: 40rpx;
  font-weight: bold;
  margin-top: 10rpx;
  display: block;
}

.header-icon {
  position: relative;
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 50%;
}

.notice-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  background-color: #ff4d4f;
  color: white;
  font-size: 20rpx;
  padding: 0 10rpx;
  border-radius: 20rpx;
  min-width: 30rpx;
  text-align: center;
  border: 2rpx solid #fff;
}

/* 3. 滚动通知栏 */
.notice-bar {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx 30rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.05);
  margin-bottom: 30rpx;
}

.notice-tag {
  background: #f0f5ff;
  color: #2f54eb;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.notice-swiper {
  flex: 1;
  height: 40rpx;
}

.notice-item {
  font-size: 26rpx;
  color: #666;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  display: block;
}

/* 4. Tab 导航优化 */
.tab-nav {
  display: flex;
  position: relative;
  margin-bottom: 30rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  font-size: 30rpx;
  color: #8c8c8c;
  transition: all 0.3s;
}

.tab-item.active {
  color: #2f54eb;
  font-weight: bold;
  font-size: 32rpx;
}

.tab-line {
  position: absolute;
  bottom: 0;
  width: 33.33%;
  height: 6rpx;
  transition: left 0.3s cubic-bezier(0.645, 0.045, 0.355, 1);
}

.tab-line-inner {
  width: 40rpx;
  height: 100%;
  background-color: #2f54eb;
  border-radius: 3rpx;
  margin: 0 auto;
}

/* 5. 工单卡片样式 */
.list-wrapper {
  height: calc(100vh - 580rpx);
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.03);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 20rpx;
}

.order-id {
  font-size: 24rpx;
  color: #bfbfbf;
  margin-bottom: 4rpx;
}

.order-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #262626;
  display: block;
}

/* 状态标签配色方案 */
.status-tag {
  display: flex;
  align-items: center;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
}

.status-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.status-0 { background: #fff1f0; color: #ff4d4f; } /* 待受理 */
.status-0 .status-dot { background: #ff4d4f; }

.status-1, .status-2 { background: #e6f7ff; color: #1890ff; } /* 进行中 */
.status-1 .status-dot, .status-2 .status-dot { background: #1890ff; }

.status-3, .status-4 { background: #f6ffed; color: #52c41a; } /* 已办结 */
.status-3 .status-dot, .status-4 .status-dot { background: #52c41a; }

.card-body {
  margin-bottom: 24rpx;
}

.content {
  font-size: 28rpx;
  color: #595959;
  line-height: 1.6;
}

.worker-info {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #f0f0f0;
  font-size: 26rpx;
}

.worker-label { color: #8c8c8c; }
.worker-name { color: #262626; font-weight: 500; }

.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #f5f5f5;
}

.time-box {
  display: flex;
  align-items: center;
}

.time {
  font-size: 24rpx;
  color: #bfbfbf;
  margin-left: 8rpx;
}

.detail-link {
  font-size: 26rpx;
  color: #2f54eb;
  display: flex;
  align-items: center;
}

.link-arrow {
  width: 12rpx;
  height: 12rpx;
  border-top: 3rpx solid #2f54eb;
  border-right: 3rpx solid #2f54eb;
  transform: rotate(45deg);
  margin-left: 8rpx;
}

/* 6. 悬浮报修按钮（适老化：超大、显眼） */
.fab-btn {
  position: fixed;
  bottom: 60rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 320rpx;
  height: 110rpx;
  z-index: 100;
}

.fab-inner {
  background: #2f54eb;
  height: 100%;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 32rpx rgba(47, 84, 235, 0.35);
  padding: 0 40rpx;
}

.fab-plus-box {
  width: 50rpx;
  height: 50rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.fab-plus {
  color: #2f54eb;
  font-size: 40rpx;
  font-weight: bold;
  line-height: 1;
  margin-top: -4rpx;
}

.fab-text {
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.fab-hover {
  transform: translateX(-50%) scale(0.95);
  opacity: 0.9;
}

/* 7. 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 120rpx;
  color: #bfbfbf;
}

.empty-img {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 20rpx;
}

.empty-btn {
  margin-top: 40rpx;
  background: #2f54eb;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  padding: 0 60rpx;
}