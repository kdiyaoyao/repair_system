<view class="notice-page">
  <view class="notice-card" wx:for="{{notices}}" wx:key="id">
    <view class="notice-header">
      <view class="dot"></view>
      <text class="notice-title">{{item.title}}</text>
    </view>
    <view class="notice-body">{{item.content}}</view>
    <view class="notice-footer">{{item.createTime}}</view>
  </view>
  <view class="empty-state" wx:if="{{notices.length === 0}}">暂无历史通知</view>
</view>