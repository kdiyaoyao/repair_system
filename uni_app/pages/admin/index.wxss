/* 1. 容器与背景 */
.admin-container {
  min-height: 100vh;
  background-color: #f7f8fa;
  padding-bottom: 40rpx;
}

/* 2. 顶部头部与统计 */
.admin-header {
  background: linear-gradient(135deg, #1890ff, #096dd9);
  padding: 40rpx 30rpx 60rpx;
  color: #fff;
}

.admin-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 30rpx;
}

.stats-box {
  display: flex;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 30rpx 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  border-right: 1rpx solid rgba(255, 255, 255, 0.2);
}

.stat-item:last-child {
  border-right: none;
}

.stat-item .num {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
}

.stat-item .lab {
  font-size: 24rpx;
  opacity: 0.8;
  margin-top: 8rpx;
  display: block;
}

/* 3. Tab 切换栏 */
.tab-box {
  display: flex;
  background: #fff;
  margin: -20rpx 30rpx 20rpx;
  border-radius: 12rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  overflow: hidden;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab-item.active {
  color: #1890ff;
  font-weight: bold;
}

.tab-item.active::after {
  content: "";
  position: absolute;
  bottom: 0;
  left: 30%;
  right: 30%;
  height: 6rpx;
  background: #1890ff;
  border-radius: 3rpx;
}

/* 4. 列表区域 */
.list-section {
  padding: 0 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin: 30rpx 0 20rpx;
}

/* 5. 工单卡片设计 */
.admin-card {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.04);
  overflow: hidden;
  border-left: 8rpx solid #ccc; /* 默认灰色 */
}

/* 状态色边框区分 */
.admin-card.card-done {
  border-left-color: #52c41a; /* 已完工-绿 */
}

/* 待受理状态突出显示 */
.admin-card:has(.tag-0) {
  border-left-color: #ff4d4f; /* 待受理-红 */
}

.admin-card-body {
  padding: 24rpx;
}

.card-header-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.order-id {
  font-size: 24rpx;
  color: #999;
}

/* 状态标签样式 */
.status-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.tag-0 { background: #fff1f0; color: #ff4d4f; border: 1rpx solid #ffa39e; } /* 待受理 */
.tag-1, .tag-2 { background: #e6f7ff; color: #1890ff; border: 1rpx solid #91d5ff; } /* 处理中 */
.tag-3, .tag-4 { background: #f6ffed; color: #52c41a; border: 1rpx solid #b7eb8f; } /* 已完成 */

.info-group {
  margin-bottom: 12rpx;
  display: flex;
  font-size: 28rpx;
  line-height: 1.5;
}

.info-group .t {
  color: #888;
  width: 150rpx;
  flex-shrink: 0;
}

.info-group .v {
  color: #333;
  word-break: break-all;
}

/* 6. 底部操作区域 */
.admin-footer {
  background: #fafafa;
  padding: 20rpx 24rpx;
  border-top: 1rpx solid #eee;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.handle-btn {
  width: 100% !important;
  background: #1890ff;
  color: #fff;
  font-size: 28rpx;
  border-radius: 40rpx;
  font-weight: normal;
}

.done-style, .processing-style {
  font-size: 26rpx;
  color: #666;
  justify-content: flex-start;
}

.done-style icon, .processing-style icon {
  margin-right: 10rpx;
}

.rating-text {
  color: #faad14;
  margin-left: 10rpx;
}

/* 7. 空状态 */
.empty-holder {
  padding: 100rpx 0;
  text-align: center;
  color: #ccc;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-holder text {
  margin-top: 20rpx;
  font-size: 28rpx;
}