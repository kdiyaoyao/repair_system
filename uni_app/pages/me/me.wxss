/* 统一命名空间，防止冲突 */
.me-container {
  min-height: 100vh;
  background-color: #f4f6fa; /* 更淡雅的背景色，衬托卡片 */
  padding: 30rpx;
  box-sizing: border-box;
}

/* 1. 用户卡片美化（金卡质感） */
.user-card {
  position: relative;
  height: 280rpx;
  background: linear-gradient(135deg, #1890ff, #2f54eb); /* 渐变蓝 */
  border-radius: 40rpx;
  overflow: hidden;
  padding: 50rpx;
  box-shadow: 0 15rpx 40rpx rgba(24, 144, 255, 0.25);
  margin-bottom: 30rpx;
}

/* 增加卡片内背景装饰 */
.card-glass-bg {
  position: absolute;
  top: -100rpx; right: -100rpx;
  width: 300rpx; height: 300rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  filter: blur(20px);
}

.card-deco {
  position: absolute;
  bottom: 20rpx; left: 50rpx;
  font-size: 20rpx; color: rgba(255, 255, 255, 0.3);
  font-family: 'Arial', sans-serif; letter-spacing: 1px;
}

.user-content {
  display: flex; align-items: center;
  position: relative; z-index: 2;
}

.avatar-box {
  width: 140rpx; height: 140rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(255, 255, 255, 0.5);
  overflow: hidden;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.1);
}

.info-box { margin-left: 40rpx; color: #fff; }

.nickname {
  font-size: 46rpx; font-weight: bold;
  display: block; text-shadow: 0 2rpx 4rpx rgba(0,0,0,0.1);
}

.role-tag {
  display: flex; align-items: center;
  background: rgba(255, 255, 255, 0.25);
  padding: 6rpx 24rpx; border-radius: 30rpx;
  margin-top: 15rpx; backdrop-filter: blur(5px);
}

.tag-text { font-size: 24rpx; margin-left: 8rpx; font-weight: 300; }

/* 2. 数据概览磁贴美化（Grid Card Design） */
.stats-board-wrapper {
  margin: 0 -10rpx 40rpx; /* 增加整体边距，衬托悬浮感 */
}

.stats-board {
  display: flex;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx 10rpx;
  position: relative; z-index: 3;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.04);
}

.stats-item {
  flex: 1; text-align: center;
  display: flex; flex-direction: column; align-items: center;
  border-right: 1rpx solid #f0f0f0;
}
.stats-item:last-child { border: none; }

.stats-icon-bg {
  width: 80rpx; height: 80rpx;
  border-radius: 24rpx;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 20rpx;
}

/* 不同状态使用不同淡色背景，增加层级 */
.stats-item.pending .stats-icon-bg { background: #fff2e8; }
.stats-item.processing .stats-icon-bg { background: #e6f7ff; }
.stats-item.completed .stats-icon-bg { background: #f6ffed; }

.stats-num {
  font-size: 44rpx; font-weight: bold; color: #262626;
  font-family: 'Helvetica Neue', Helvetica, sans-serif;
  display: block;
}

.stats-label { font-size: 26rpx; color: #8c8c8c; margin-top: 10rpx; }

/* 3. 功能菜单网格优化（大点击区域，适老化体现） */
.function-grid { margin-top: 40rpx; }

.grid-item {
  display: flex; align-items: center;
  background: #fff;
  border-radius: 32rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.02);
  position: relative;
  transition: all 0.2s ease;
}

/* 增加点击态反馈 */
.grid-item:active {
  background-color: #fbfbfb;
  transform: scale(0.99);
}

.grid-icon-box {
  width: 100rpx; height: 100rpx;
  border-radius: 28rpx;
  display: flex; align-items: center; justify-content: center;
  margin-right: 35rpx;
}
.bg-light-blue { background: #e6f7ff; }
.bg-light-green { background: #f6ffed; }

.grid-text-box { flex: 1; display: flex; flex-direction: column; }
.grid-title { font-size: 34rpx; color: #262626; font-weight: bold; }
.grid-desc { font-size: 26rpx; color: #bfbfbf; margin-top: 6rpx; }

.grid-arrow { position: absolute; right: 40rpx; top: 50%; transform: translateY(-50%); }

/* 4. 底部工具栏美化（极简） */
.footer-section { margin-top: 80rpx; padding-bottom: 40rpx; text-align: center; }

.logout-btn-plain {
  background: transparent !important;
  display: flex; align-items: center; justify-content: center;
  width: auto !important;
  margin: 0 auto !important;
  padding: 20rpx 40rpx !important;
  border-radius: 40rpx;
  color: #ff4d4f; font-weight: 300;
}
.logout-btn-plain:active { background: rgba(255, 77, 79, 0.05) !important; }
.logout-text { margin-left: 10rpx; font-size: 28rpx; }

.version-info { font-size: 24rpx; color: #d9d9d9; margin-top: 40rpx; line-height: 1.6; }
.version-num { margin-left: 10rpx; }