.password-page {
  min-height: 100vh;
  background-color: #f8f9fc;
  padding: 40rpx;
}

.header-tip {
  display: flex;
  align-items: center;
  padding: 24rpx 30rpx;
  background: #e6f7ff;
  border-radius: 16rpx;
  margin-bottom: 40rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #1890ff;
  margin-left: 16rpx;
}

.form-container {
  background: #ffffff;
  border-radius: 32rpx;
  padding: 40rpx 30rpx;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.02);
}

.input-group {
  margin-bottom: 40rpx;
  border-bottom: 2rpx solid #f0f0f0;
  padding-bottom: 10rpx;
  transition: all 0.3s;
}

.input-group.active {
  border-bottom-color: #1890ff;
}

.label {
  font-size: 28rpx;
  color: #8c8c8c;
  margin-bottom: 16rpx;
  display: block;
}

.main-input {
  height: 80rpx;
  font-size: 32rpx;
  color: #262626;
}

.ph-style {
  color: #bfbfbf;
}

.submit-btn {
  margin-top: 60rpx;
  background: linear-gradient(135deg, #1890ff, #2f54eb) !important;
  color: #ffffff !important;
  border-radius: 44rpx;
  font-weight: bold;
  height: 90rpx;
  line-height: 90rpx;
  border: none;
  font-size: 30rpx;
}

.btn-loading {
  opacity: 0.7;
}

.footer-note {
  text-align: center;
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #bfbfbf;
}