<view class="password-page">
  <view class="header-tip">
    <icon type="info" size="18" color="#1890ff"></icon>
    <text class="tip-text">为了您的账号安全，修改密码后需重新登录</text>
  </view>

  <view class="form-container">
    <view class="input-group {{password ? 'active' : ''}}">
      <view class="label-row">
        <text class="label">新密码</text>
      </view>
      <input 
        password 
        class="main-input"
        placeholder="请输入新密码" 
        placeholder-class="ph-style"
        bindinput="handleInput" 
        data-name="password"
        value="{{password}}"
      />
    </view>

    <view class="input-group {{confirm ? 'active' : ''}}">
      <view class="label-row">
        <text class="label">确认密码</text>
      </view>
      <input 
        password 
        class="main-input"
        placeholder="请再次输入新密码" 
        placeholder-class="ph-style"
        bindinput="handleInput" 
        data-name="confirm"
        value="{{confirm}}"
      />
    </view>

    <button 
      class="submit-btn {{loading ? 'btn-loading' : ''}}" 
      bindtap="updatePassword"
      loading="{{loading}}"
      disabled="{{loading}}"
    >
      {{loading ? '正在安全提交...' : '确认修改密码'}}
    </button>
  </view>

  <view class="footer-note">
    <text>密码长度需在 6-18 位之间</text>
  </view>
</view>